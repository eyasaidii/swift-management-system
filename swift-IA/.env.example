APP_NAME=btl-swift-ai
APP_ENV=production
DEBUG=false

# Seuil de score pour considérer une anomalie (0.0 - 1.0)
ANOMALY_THRESHOLD=0.65

# Isolation Forest contamination rate
IF_CONTAMINATION=0.05

# Chemin vers les modèles sauvegardés
MODEL_DIR=./model

# Chemin vers les données
DATA_DIR=./data

# URL Laravel (callback)
LARAVEL_BASE_URL=http://btl_swift_app:8000
LARAVEL_API_KEY=

# CORS origins autorisées
CORS_ORIGINS=http://localhost,http://btl_swift_app:8000

# ── Variables utilisées côté Laravel (à ajouter dans .env Laravel) ──
# AI_SERVICE_URL=http://python-api:8001
# AI_SERVICE_TIMEOUT=5
